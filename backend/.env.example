# Copy this file to .env and fill in your keys
OPENAI_API_KEY=your_openai_key
PINECONE_API_KEY=your_pinecone_key
PINECONE_INDEX_NAME=legacylens

# If you get 401 Invalid API Key, add your index host from the Pinecone dashboard
# (Indexes → your index → copy the Host value). This skips control-plane auth.
# PINECONE_INDEX_HOST=legacylens-xxxxx.svc.region.pinecone.io

# Pinecone index: create with dimensions=1024, metric=cosine (matches text-embedding-3-small)
